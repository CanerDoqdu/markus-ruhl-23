# Contact route: origin/CORS guard
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Contact route: rate limiting
CONTACT_RATE_LIMIT_WINDOW_MS=60000
CONTACT_RATE_LIMIT_MAX=5

# Contact route: mail addressing
# CONTACT_MAIL_TO is where incoming submissions are delivered.
# CONTACT_MAIL_FROM is the sender address shown in the received email.
# Both have code-level defaults but MUST be set explicitly in production.
CONTACT_MAIL_TO=contact@example.com
CONTACT_MAIL_FROM=noreply@example.com

# Contact route: mail dispatch timeout (ms). Default: 10000.
# Increase only if your mail provider has known high latency.
CONTACT_MAIL_TIMEOUT_MS=10000

# Optional distributed rate limiting (use one)
# REDIS_URL=redis://localhost:6379
# REDIS_HOST=localhost

# Contact route: mail provider placeholders
# (route includes provider guidance in comments; keep empty unless used)
RESEND_API_KEY=
SENDGRID_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
