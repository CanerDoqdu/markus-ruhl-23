# Site Configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# 3D Features (currently disabled due to compatibility issues)
# Uncomment to enable 3D hero scene (requires fixing React Three Fiber)
# NEXT_PUBLIC_ENABLE_3D=true

# Optional: Redis connection for multi-instance rate limiting.
# When set, the contact API rate limiter stores state in Redis so all server
# instances share the same counter — required for multi-instance deployments.
# Omit (or leave commented out) to use the in-memory fallback, which is safe
# for single-instance servers, local dev, and CI without a Redis sidecar.
# REDIS_URL=redis://localhost:6379
# REDIS_HOST=localhost   # Alternative to REDIS_URL (used when REDIS_URL is absent)
